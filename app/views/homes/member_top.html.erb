<div class="member_top">
  <div class="hero-card">
    <div class="hero-logo">
      <%= image_tag("rhythm_raiders_logo2.jpg", alt: "Rhythm Raiders") %>
    </div>

    <p class="hero-tagline">
      Common throughout the world&hellip; <span>It's Music</span>
    </p>

    <%= form_with(url: search_index_path, method: "get", local: true, class: "hero-search") do |form| %>
      <%= form.text_field :keyword, placeholder: "Search tracks…", class: "hero-search__input" %>
      <%= form.submit "Search", class: "hero-search__btn" %>
    <% end %>

    <nav class="hero-nav">
      <%= link_to "Guest Sign In", member_customers_guest_sign_in_path, method: :post, class: "neon-btn" %>
      <%= link_to "Sign Up", new_member_registration_path, class: "neon-btn" %>
      <%= link_to "Log In", member_session_path, class: "neon-btn" %>
      <%= link_to "About", "/homes/about", class: "neon-btn" %>
      <%= link_to "♪ Music Index", member_created_tracks_path, class: "neon-btn neon-btn--primary" %>
      <%= link_to "Log Out", destroy_member_session_path, method: :delete, class: "neon-btn neon-btn--ghost" %>
    </nav>

    <p class="hero-desc">
      「Rhythm RAIDERS」はゲーム音楽制作者とファンをつなぐ投稿コミュニティサイトです。<br>
      A platform bridging game music composers and enthusiasts.
    </p>
  </div>
</div>
