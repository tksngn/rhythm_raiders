<div class="member-list">
  <div class="member-list__inner">
    <h1 class="ml-title">Member <span>Profile</span></h1>

    <section class="mp-card mp-card--profile" style="width:100%; max-width:520px;">
      <div class="mp-avatar">
        <%= image_tag @member.get_profile_image(120, 120) %>
      </div>
      <p class="mp-name"><%= @member.creater_name %></p>

      <% if current_member != @member %>
        <div class="ts-actions" style="justify-content:center; margin-top:12px;">
          <% if current_member.following?(@member) %>
            <%= link_to 'フォロー外す', member_customer_relationships_path(@member), method: :delete, class: "ts-btn ts-btn--danger" %>
          <% else %>
            <%= link_to 'フォローする', member_customer_relationships_path(@member), method: :post, class: "ts-btn ts-btn--primary" %>
          <% end %>
        </div>
      <% end %>
    </section>

    <section class="mp-card" style="width:100%;">
      <h3 class="mp-heading">Posted <span>Tracks</span></h3>
      <% if @member.created_tracks.any? %>
        <% @member.created_tracks.each do |created_track| %>
          <div class="mp-track">
            <h4 class="mp-track__title">
              <%= link_to created_track.music_title, member_created_track_path(created_track.id) %>
            </h4>
            <p class="mp-track__meta">Genre : <%= created_track.music_genre %></p>
            <p class="mp-track__word"><%= created_track.creater_word %></p>
            <div class="mp-track__actions">
              <%= link_to "#{created_track.post_comments.count} Comments", member_created_track_path(created_track.id), class: "mp-link" %>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="mp-empty">まだ投稿がありません。</p>
      <% end %>
    </section>

    <%= link_to "♪ Music Index", member_created_tracks_path, class: "neon-btn neon-btn--primary hero-logout" %>
  </div>
</div>
