<div class="mypage">
  <div class="mypage__inner">
    <div class="hero-logo">
      <%= image_tag("rhythm_raiders_logo2.jpg", alt: "Rhythm Raiders") %>
    </div>

    <div class="mypage__grid">
      <div class="mypage__col">
        <!-- Profile -->
        <section class="mp-card mp-card--profile">
          <h3 class="mp-heading">My <span>Page</span></h3>
          <div class="mp-avatar">
            <%= image_tag @member.get_profile_image(120, 120) %>
          </div>
          <p class="mp-name"><%= @member.name %></p>
          <p class="mp-creator">( <%= @member.creater_name %> )</p>
        </section>

        <!-- My Tracks -->
        <section class="mp-card">
          <h3 class="mp-heading">My <span>Tracks</span></h3>
          <% if @member.created_tracks.any? %>
            <% @member.created_tracks.each do |created_track| %>
              <div class="mp-track">
                <h4 class="mp-track__title">
                  <%= link_to created_track.music_title, member_created_track_path(created_track.id) %>
                </h4>
                <p class="mp-track__meta">Genre : <%= created_track.music_genre %></p>
                <p class="mp-track__word"><%= created_track.creater_word %></p>
                <div class="mp-track__actions">
                  <%= link_to "#{created_track.post_comments.count} Comments", member_created_track_path(created_track.id), class: "mp-link" %>
                  <%= link_to "Delete",
                      member_created_track_path(created_track.id),
                      method: :delete,
                      data: { confirm: "削除してもよろしいですか？" },
                      class: "mp-link mp-link--danger" %>
                </div>
              </div>
            <% end %>
          <% else %>
            <p class="mp-empty">まだ投稿がありません。</p>
          <% end %>
        </section>
      </div>

      <div class="mypage__col">
        <!-- Follow / Follower -->
        <section class="mp-card">
          <h3 class="mp-heading">Follow / <span>Follower</span></h3>
          <div class="mp-stats">
            <%= link_to followers_member_customer_path(current_member), class: "mp-stat" do %>
              <strong><%= @follower_members.count %></strong> Follower
            <% end %>
            <%= link_to follows_member_customer_path(current_member), class: "mp-stat" do %>
              <strong><%= @following_members.count %></strong> Following
            <% end %>
          </div>
        </section>

        <!-- Good Sound -->
        <section class="mp-card">
          <h3 class="mp-heading">Good <span>Sound</span></h3>
          <% if @member.likes.any? %>
            <% @member.likes.each do |like| %>
              <div class="mp-like">
                ♥ <%= link_to like.created_track.music_title, member_created_track_path(like.created_track) %>
              </div>
            <% end %>
          <% else %>
            <p class="mp-empty">いいねした楽曲がありません。</p>
          <% end %>
        </section>

        <!-- Information -->
        <section class="mp-card">
          <h3 class="mp-heading"><span>Information</span></h3>
          <nav class="mp-nav">
            <%= link_to "♪ Music Index", member_created_tracks_path, class: "mp-navlink" %>
            <%= link_to "Home", member_top_path, class: "mp-navlink" %>
            <%= link_to "About", "/homes/about", class: "mp-navlink" %>
            <%= link_to "Edit & Post music", new_member_created_track_path, class: "mp-navlink mp-navlink--accent" %>
            <%= link_to notifications_path, class: "mp-navlink" do %>
              <% if current_member.notifications.where(checked: false).exists? %>
                <i class="fa-sharp fa-solid fa-bell fa-beat" style="color: #f2ee7d;"></i>
              <% else %>
                <i class="fa-sharp fa-solid fa-bell"></i>
              <% end %>
              通知一覧
            <% end %>
          </nav>
        </section>
      </div>
    </div>
  </div>
</div>
