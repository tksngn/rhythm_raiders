<div class="member_login">
  <div class="hero-card auth-card">
    <div class="hero-logo">
      <%= image_tag("rhythm_raiders_logo2.jpg", alt: "Rhythm Raiders") %>
    </div>

    <h2 class="auth-title">Member <span>Log In</span></h2>

    <% if flash[:notice] %>
      <div class="auth-flash"><%= flash[:notice] %><% flash.discard(:notice) %></div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: new_member_session_path, html: { class: "auth-form" }) do |form| %>
      <div class="auth-field">
        <%= form.label :email, "Email" %>
        <%= form.email_field :email, class: "auth-input", required: true, autofocus: true %>
      </div>
      <div class="auth-field">
        <%= form.label :password, "Password" %>
        <%= form.password_field :password, class: "auth-input", required: true %>
      </div>
      <%= form.submit "LOG IN", class: "neon-btn neon-btn--primary auth-submit" %>
    <% end %>

    <p class="hero-tagline auth-tagline">Now, let's go on a <span>Musical Adventure!</span></p>

    <%= link_to "← Back to Top", root_path, class: "neon-btn neon-btn--ghost hero-logout" %>
  </div>
</div>
