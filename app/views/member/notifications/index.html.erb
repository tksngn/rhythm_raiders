<div class="notif-page">
  <div class="notif-page__inner">
    <section class="mp-card" style="width:100%;">
      <h3 class="mp-heading">通知 <span>Notifications</span></h3>

      <% if @notifications.present? %>
        <div class="text-center" style="margin-bottom:14px;">
          <%= link_to "全削除", notification_path(@notifications), method: :delete, class: "ts-btn ts-btn--danger" %>
        </div>
        <% @notifications.each do |notification| %>
          <div class="notif-item">
            <%= render "#{notification.subject.class.name.downcase}", notification: notification %>
          </div>
        <% end %>
      <% else %>
        <p class="mp-empty">通知はありません。</p>
      <% end %>
    </section>

    <%= link_to "← Back to Mypage", mypage_member_customers_path, class: "neon-btn neon-btn--ghost hero-logout" %>
  </div>
</div>
