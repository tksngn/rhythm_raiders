<div class="member-track-show">
  <div class="form-page__inner">
    <div class="hero-logo">
      <%= image_tag("rhythm_raiders_logo2.jpg", alt: "Rhythm Raiders") %>
    </div>

    <!-- 会員情報の編集 -->
    <section class="form-card">
      <h2 class="about-heading">§ Edit Member Information §</h2>
      <%= form_with model: @member, url: member_customer_path(@member), method: :patch, html: { class: "auth-form" } do |f| %>
        <%= render 'layouts/errors', model: @member %>
        <div class="auth-field">
          <%= f.label :name, "Name" %>
          <%= f.text_field :name, class: "auth-input" %>
        </div>
        <div class="auth-field">
          <%= f.label :creater_name, "Creator Name" %>
          <%= f.text_field :creater_name, class: "auth-input" %>
        </div>
        <div class="auth-field">
          <%= f.label :profile_image, "Profile Image" %>
          <%= f.file_field :profile_image, class: "auth-input auth-input--file" %>
        </div>
        <div class="auth-field">
          <%= f.label :email, "Email" %>
          <%= f.email_field :email, class: "auth-input" %>
        </div>
        <div class="auth-field">
          <%= f.label :phone_number, "Phone Number" %>
          <%= f.telephone_field :phone_number, class: "auth-input" %>
        </div>
        <div class="auth-field">
          <%= f.label :gender, "Gender" %>
          <%= f.select :gender, ['Male', 'Female', 'Non_binary'], {}, class: "auth-input" %>
        </div>
        <%= f.submit "Save Changes / 変更を保存", class: "neon-btn neon-btn--primary auth-submit" %>
      <% end %>
    </section>

    <!-- 楽曲投稿 -->
    <section class="form-card">
      <h2 class="about-heading">§ Post Music §</h2>
      <%= form_with model: [:member, @created_track], html: { class: "auth-form" } do |f| %>
        <%= render 'layouts/errors', model: @created_track %>
        <div class="auth-field">
          <%= f.label :music_title, "Music Title" %>
          <%= f.text_field :music_title, class: "auth-input" %>
        </div>
        <div class="auth-field">
          <%= f.label :music_file, "Music File" %>
          <%= f.file_field :music_file, class: "auth-input auth-input--file" %>
        </div>
        <div class="auth-field">
          <%= f.label :music_genre, "Music Genre" %>
          <%= f.text_field :music_genre, class: "auth-input" %>
        </div>
        <div class="auth-field">
          <%= f.label :creater_word, "Creator Word" %>
          <%= f.text_area :creater_word, rows: 4, class: "auth-input" %>
        </div>
        <%= f.submit "Post Music / 楽曲を投稿", class: "neon-btn neon-btn--primary auth-submit" %>
      <% end %>
    </section>

    <%= link_to "退会する / Unsubscribe", unsubscribe_member_customers_path, class: "neon-btn neon-btn--ghost hero-logout" %>
  </div>
</div>
