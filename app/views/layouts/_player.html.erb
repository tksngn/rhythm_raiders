<div id="waveform_<%= created_track.id %>" class="wave-canvas"></div>

<div class="wave-controls mt-1">
  <div class="wave-controls__btns">
    <a class="wave-btn wave-btn--play" onclick="wavesurfer_<%= created_track.id %> && wavesurfer_<%= created_track.id %>.playPause();">▶ PLAY / STOP</a>
    <a class="wave-btn wave-btn--restart" onclick="wavesurfer_<%= created_track.id %> && (wavesurfer_<%= created_track.id %>.stop(), wavesurfer_<%= created_track.id %>.play());">⟲ Start Over</a>
  </div>
  <a id="time_<%= created_track.id %>" class="wave-time"></a>
</div>

<div class="wave-volume mt-1">
  <label for="volume_<%= created_track.id %>">Volume</label>
  <input type="range" class="custom-range" id="volume_<%= created_track.id %>" value="50">
</div>

<script>
(function () {
  var cid = "<%= created_track.id %>";

  function initWave_<%= created_track.id %>() {
    if (typeof WaveSurfer === "undefined") return;
    var container = document.getElementById("waveform_" + cid);
    if (!container) return;

    // 既存インスタンスがあれば破棄してから作り直す（turbolinks再訪やキャッシュ対策）
    if (window.wavesurfer_<%= created_track.id %> && window.wavesurfer_<%= created_track.id %>.destroy) {
      try { window.wavesurfer_<%= created_track.id %>.destroy(); } catch (e) {}
    }
    container.innerHTML = "";

    var ws = WaveSurfer.create({
      container: container,
      barWidth: 5,
      barGap: 1,
      waveColor: "#00ffcc",
      cursorColor: "#ffffff",
      progressColor: "#b06cff",
      url: "<%= j created_track.music_file.to_s %>",
      normalize: true,
      barHeight: 0.6,
      height: 64
    });
    window.wavesurfer_<%= created_track.id %> = ws;

    ws.setVolume(0.5);

    ws.on("timeupdate", function (currentTime) {
      <% if is_guest %>
      if (currentTime >= 30) { ws.stop(); }
      <% end %>
      var t = document.getElementById("time_" + cid);
      if (t) t.textContent = parseInt(currentTime) + " sec.";
    });

    var vol = document.getElementById("volume_" + cid);
    if (vol) {
      vol.addEventListener("input", function () { ws.setVolume(this.value / 100); });
    }
  }

  // WaveSurfer はヘッダーのpackで読込済みのはずなので即時初期化。
  // 万一未読込でも turbolinks:load / DOMContentLoaded で一度だけ初期化する。
  if (typeof WaveSurfer !== "undefined") {
    initWave_<%= created_track.id %>();
  } else {
    document.addEventListener("turbolinks:load", initWave_<%= created_track.id %>, { once: true });
    document.addEventListener("DOMContentLoaded", initWave_<%= created_track.id %>, { once: true });
  }
})();
</script>
