<div class="search_top">
  <div class="search-page__inner">
    <h1 class="ml-title">Search <span>Results</span></h1>

    <% if @results.blank? %>
      <p class="mp-empty">検索結果はありません。</p>
    <% else %>
      <div class="member-list__grid">
        <% @results.each do |result| %>
          <%= link_to member_created_track_path(result), class: "ml-card" do %>
            <div class="ml-card__meta">
              <p class="ml-card__name"><%= result.music_title %></p>
              <p class="ml-card__bio"><%= result.music_genre %></p>
              <p class="ml-card__count"><%= result.member.creater_name %></p>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%= link_to "← Back to Top", root_path, class: "neon-btn neon-btn--ghost hero-logout" %>
  </div>
</div>
