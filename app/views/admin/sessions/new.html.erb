<div class="admin-page admin-page--center">
  <div class="admin-card admin-auth">
    <div class="admin-logo">
      <%= link_to root_path do %>
        <%= image_tag "rhythm_raiders_logo2.jpg", alt: "Rhythm Raiders" %>
      <% end %>
    </div>

    <h2 class="auth-title">Admin <span>Log In</span></h2>

    <% if flash[:notice] %>
      <div class="auth-flash"><%= flash[:notice] %><% flash.discard(:notice) %></div>
    <% end %>

    <%= form_for(resource, as: resource_name, url: admin_session_path, html: { class: "auth-form" }) do |form| %>
      <div class="auth-field">
        <%= form.label :email, "Email" %>
        <%= form.email_field :email, id: "admin_email", class: "auth-input", required: true, autofocus: true %>
      </div>
      <div class="auth-field">
        <%= form.label :password, "Password" %>
        <%= form.password_field :password, id: "admin_password", class: "auth-input", required: true %>
      </div>
      <%= form.submit "LOG IN", class: "neon-btn neon-btn--primary auth-submit" %>
    <% end %>

    <%= link_to "← Back to Top", root_path, class: "admin-btn-ghost" %>
  </div>
</div>
