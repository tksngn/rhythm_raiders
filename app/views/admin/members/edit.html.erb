<div class="admin-page">
  <div class="admin-page__inner">
    <h1 class="admin-title">Member <span>情報編集</span></h1>

    <section class="admin-card admin-detail">
      <div class="text-center" style="margin-bottom:12px;">
        <%= image_tag (@member.profile_image.present? ? @member.profile_image : "no_image.jpg"), class: "profile-img" %>
      </div>
      <p><strong>Name:</strong> <%= @member.name %></p>
      <p><strong>Creator Name:</strong> <%= @member.creater_name %></p>
      <p><strong>Email:</strong> <%= @member.email %></p>
      <p><strong>Phone:</strong> <%= @member.phone_number %></p>
      <p><strong>Gender:</strong> <%= @member.gender %></p>

      <%= form_with(model: @member, url: admin_member_path(@member), method: :patch, local: true) do |form| %>
        <h2 class="admin-heading" style="margin-top:18px;">アカウント状態</h2>
        <label class="auth-radio" style="color:#16202a;">
          <%= form.radio_button :is_active, true %> <span style="color:#0b8f80;">利用中（有効）</span>
        </label>
        <label class="auth-radio" style="color:#16202a;">
          <%= form.radio_button :is_active, false %> <span style="color:#c0392b;">利用停止</span>
        </label>

        <div class="admin-actions">
          <%= form.submit "変更を保存", class: "neon-btn neon-btn--primary" %>
          <%= link_to "← 戻る", admin_member_path(@member), class: "admin-btn-ghost" %>
        </div>
      <% end %>
    </section>
  </div>
</div>
