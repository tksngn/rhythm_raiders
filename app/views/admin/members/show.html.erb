<div class="admin-page">
  <div class="admin-page__inner">
    <h1 class="admin-title">Member <span>詳細</span></h1>

    <section class="admin-card admin-detail">
      <h2 class="admin-heading">メンバー情報</h2>
      <div class="text-center" style="margin-bottom:12px;">
        <%= image_tag (@member.profile_image.present? ? @member.profile_image : "no_image.jpg"), class: "profile-img" %>
      </div>
      <p><strong>Name:</strong> <%= @member.name %></p>
      <p><strong>Creator Name:</strong> <%= @member.creater_name %></p>
      <p><strong>Email:</strong> <%= @member.email %></p>
      <p><strong>Phone:</strong> <%= @member.phone_number %></p>
      <p><strong>Gender:</strong> <%= @member.gender %></p>
      <p><strong>Status:</strong>
        <% if @member.is_active %>
          <span class="admin-badge admin-badge--active">有効</span>
        <% else %>
          <span class="admin-badge admin-badge--banned">停止</span>
        <% end %>
      </p>
    </section>

    <section class="admin-card">
      <h2 class="admin-heading">投稿コメント</h2>
      <% if @member.post_comments.any? %>
        <% @member.post_comments.each do |comment| %>
          <div class="admin-detail" style="border-bottom:1px solid rgba(20,40,50,0.12); padding:8px 0;">
            <% if comment.removed_by_admin? %>
              <p style="opacity:0.6; font-style:italic;">（運営により削除済み）<%= comment.comment_content %></p>
            <% else %>
              <p><%= comment.comment_content %></p>
              <%= link_to "削除", admin_post_comment_path(comment.created_track, comment), method: :delete, data: { confirm: "このコメントを運営として削除しますか？" }, class: "admin-btn-ghost" %>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <p>コメントはありません。</p>
      <% end %>
    </section>

    <section class="admin-card">
      <h2 class="admin-heading">投稿楽曲</h2>
      <% if @member.created_tracks.any? %>
        <% @member.created_tracks.each do |created_track| %>
          <div class="admin-detail" style="border-bottom:1px solid rgba(20,40,50,0.12); padding:8px 0;">
            <p><strong>Title:</strong> <%= created_track.music_title %></p>
            <p><strong>Genre:</strong> <%= created_track.music_genre %></p>
            <p><strong>Word:</strong> <%= created_track.creater_word %></p>
            <%= link_to "Track Delete", admin_created_track_path(created_track.id), method: :delete, data: { confirm: "削除してもよろしいですか？" }, class: "admin-btn-ghost" %>
          </div>
        <% end %>
      <% else %>
        <p>トラックが存在しません。</p>
      <% end %>
    </section>

    <div class="admin-actions">
      <%= link_to "メンバー情報を編集", edit_admin_member_path(@member), class: "neon-btn neon-btn--primary" %>
      <%= link_to "← 一覧へ", admin_members_path, class: "admin-btn-ghost" %>
    </div>
  </div>
</div>
