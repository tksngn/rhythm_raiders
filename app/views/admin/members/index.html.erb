<div class="admin-page">
  <div class="admin-page__inner">
    <h1 class="admin-title">Member <span>管理</span></h1>

    <div class="admin-card">
      <div class="table-responsive">
        <table class="admin-table">
          <thead>
            <tr>
              <th>UserName</th>
              <th>Status</th>
              <th>Tracks</th>
              <th>Comments</th>
            </tr>
          </thead>
          <tbody>
            <% @members.each do |member| %>
              <tr>
                <td><%= link_to member.name, admin_member_path(member) %></td>
                <td>
                  <% if member.is_active %>
                    <span class="admin-badge admin-badge--active">有効</span>
                  <% else %>
                    <span class="admin-badge admin-badge--banned">停止</span>
                  <% end %>
                </td>
                <td><%= link_to (member.created_tracks.count > 0 ? member.created_tracks.count : 'No track'), admin_member_path(member) %></td>
                <td><%= link_to (member.post_comments.count > 0 ? member.post_comments.count : 'No comment'), admin_member_path(member) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="text-center">
      <% if @members.empty? %>
        <p>メンバーが見つかりません。</p>
      <% else %>
        <%= paginate @members %>
      <% end %>
    </div>
  </div>
</div>
